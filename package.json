{
  "name": "borgwarehouse",
  "version": "3.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm exec eslint",
    "test": "vitest",
    "migrate:auth": "tsx scripts/migrate-users.ts",
    "reset:password": "tsx scripts/reset-password.ts",
    "revoke:sessions": "tsx scripts/revoke-sessions.ts",
    "setup": "pnpm install && pnpm run setup:hooks",
    "setup:hooks": "pnpm exec husky install",
    "format": "prettier --write \"{Components,Containers,helpers,pages,styles}/**/*.{js,jsx,ts,tsx,json,css,scss,md}\""
  },
  "dependencies": {
    "@tabler/icons-react": "^3.44.0",
    "async-mutex": "^0.5.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.11",
    "better-sqlite3": "^12.10.0",
    "chart.js": "^4.5.1",
    "date-fns": "^4.3.0",
    "lowdb": "^7.0.1",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.8",
    "nprogress": "^0.2.0",
    "react": "^19.2.6",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-select": "^5.10.2",
    "react-toastify": "^11.1.0",
    "swr": "^2.4.1",
    "use-media": "^1.5.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19.2.15",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "husky": "^9.1.7",
    "node-mocks-http": "^1.17.2",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
