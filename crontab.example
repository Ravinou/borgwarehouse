# BorgWarehouse cron jobs
# Adjust frequency to your needs. Default: every hour.
# Documentation: https://borgwarehouse.com/docs/admin-manual/scheduled-tasks/
#
# Status check: updates repo status (last save, alert state) and sends notifications
0 * * * * curl -sf "http://borgwarehouse:3000/api/v1/cron/status?key=$CRONJOB_KEY"
# Storage check: updates storage usage for each repository
0 * * * * curl -sf "http://borgwarehouse:3000/api/v1/cron/storage?key=$CRONJOB_KEY"
